{% extends 'base.html.twig' %}

{% block title %}ListItem{% endblock %}

{% block body %}
    <h1>ListItem</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ list_item.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ list_item.title }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ list_item.createdAt ? list_item.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_list_item_index') }}">back to list</a>

    <a href="{{ path('app_list_item_edit', {'id': list_item.id}) }}">edit</a>

    {{ include('list_item/_delete_form.html.twig') }}
{% endblock %}
